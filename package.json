{
  "name": "metaverse2d",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @metaverse2d/web",
    "dev:web": "npm run dev --workspace @metaverse2d/web",
    "dev:server": "npm run dev --workspace @metaverse2d/server",
    "build": "npm run build --workspaces",
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.4.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
