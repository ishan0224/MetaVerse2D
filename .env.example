# Root-level env template (legacy/optional).
# Preferred setup: keep env per app:
# - frontend in apps/web/.env
# - backend in apps/server/.env
NODE_ENV=development

# Frontend
NEXT_PUBLIC_APP_NAME=MetaVerse2D
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
NEXT_PUBLIC_WEBRTC_STUN_URLS=stun:stun.l.google.com:19302
NEXT_PUBLIC_WEBRTC_TURN_URLS=turn:<turn-host>:3478?transport=udp,turn:<turn-host>:3478?transport=tcp
NEXT_PUBLIC_WEBRTC_TURN_USERNAME=<turn-username>
NEXT_PUBLIC_WEBRTC_TURN_CREDENTIAL=<turn-password>
ALLOWED_DEV_ORIGINS=http://localhost:3000

# Backend
SERVER_PORT=4000
CLIENT_ORIGIN=http://localhost:3000
CLIENT_ORIGIN_PREVIEW=
ALLOW_DEV_TUNNEL_ORIGINS=false
SERVER_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres?sslmode=require
SERVER_SUPABASE_URL=https://<project-ref>.supabase.co
SERVER_SUPABASE_ANON_KEY=<supabase-anon-key>
